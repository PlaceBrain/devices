APP__DEBUG=false
APP__PORT=50053

LOGGING__LEVEL=info

DATABASE__URL=postgresql+asyncpg://backend:change-me@placebrain-database:5432/devices_db
DATABASE__ECHO=false
DATABASE__POOL_SIZE=10

# EMQX broker — used to publish device commands.
MQTT__URL=mqtt://placebrain-emqx:1883

# Redis — role cache + short-lived MQTT user credentials.
REDIS__URL=redis://placebrain-redis:6379/0

# Kafka — consume places/telemetry events, produce device/threshold events.
KAFKA__URL=placebrain-kafka:19092
